PORT=8081
# Comma-separated list (recommended for production). For local dev:
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# optional: openai | gemini (if empty, backend tries OpenAI then Gemini)
LLM_PROVIDER=openai

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI / OpenRouter (recommended) ---
# For OpenRouter, set:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini (example)
OPENAI_API_KEY=your_openrouter_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
# Optional (recommended by OpenRouter for attribution/limits)
OPENAI_HTTP_REFERER=http://localhost:5174
OPENAI_APP_TITLE=AI Math Doubt Solver

